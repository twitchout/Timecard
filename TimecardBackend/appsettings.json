{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=timecard.db"
  },
  "TimeCardSettings": {
    "RegularHoursPerDay": 8.0,
    "RegularHoursPerWeek": 40.0,
    "OvertimeMultiplier": 1.5,
    "MaxHoursPerDay": 24,
    "MinBreakMinutes": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}