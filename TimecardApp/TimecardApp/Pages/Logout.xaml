<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimecardApp.Pages.Logout"
             Title="Logout">
    
    <VerticalStackLayout
        Padding="30,0"
        Spacing="25"
        VerticalOptions="Center">

        <Border
            StrokeShape="RoundRectangle 10"
            MaximumWidthRequest="500"
            Margin="0,0,0,50">

            <StackLayout
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                Padding="30"
                Spacing="20">
                
                <Label 
                    Text="Confirm Logout"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Style="{StaticResource Headline}"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    SemanticProperties.HeadingLevel="Level1" />

                <Label
                    Text="Are you sure you want to log out?"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    FontSize="Medium"
                    Margin="0,10,0,20"
                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    SemanticProperties.HeadingLevel="Level2" />
                
                <Button
                    Text="Yes, Log Out"
                    x:Name="ConfirmLogoutBtn"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    SemanticProperties.Hint="Confirm logout action" />
                
                <Button
                    Text="Cancel"
                    x:Name="CancelBtn"
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                    BorderWidth="2"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                    SemanticProperties.Hint="Cancel logout and return" />
                
            </StackLayout>
        </Border>

        <Label 
            Text=""
            x:Name="LogoutAlert"
            Style="{StaticResource SubHeadline}"
            HorizontalOptions="Center"
            SemanticProperties.HeadingLevel="Level2"
            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

    </VerticalStackLayout>
</ContentPage>
