<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimecardApp.Pages.Timeclock"
             Title="Timeclock">
    
    <VerticalStackLayout
        Padding="30,0"
        Spacing="20"
        VerticalOptions="Center">

        <Border
            StrokeShape="RoundRectangle 10"
            MaximumWidthRequest="750"
            Margin="0,0,0,100">

            <StackLayout
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                Padding="15">
                
                <Label 
                    Text="Time Clock"
                    VerticalOptions="Center"
                    Style="{StaticResource Headline}"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    SemanticProperties.HeadingLevel="Level1" />

                <!-- shameless midnight burger reference -->
                <Label
                  Text="Let's start the shift!"
                  x:Name="GreetingLabel"
                  VerticalOptions="Center"
                  HorizontalOptions="Center"
                  FontSize="Medium"
                    Margin="0,20,0,0"
                  Style="{StaticResource SubHeadline}"
                  TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                  SemanticProperties.HeadingLevel="Level2" />

                <!-- Notes Entry (only visible when clocking out) -->
                <Label
                    x:Name="NotesLabel"
                    Text="Notes (Optional):"
                    Margin="0,20,0,5"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    IsVisible="False" />
                <Editor
                    x:Name="NotesEntry"
                    Placeholder="Add any notes about this shift..."
                    HeightRequest="80"
                    MaxLength="500"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    IsVisible="False" />

                <Button
                    Text="Clock In"
                    Margin="0, 20, 0, 0"
                    x:Name="TimePunchBtn"
                    SemanticProperties.Hint="Punches the time clock" />

                <Button
                    Text="View My Timecard"
                    Margin="0, 15, 0, 0"
                    x:Name="ViewTimecardBtn"
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    BorderWidth="2"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    SemanticProperties.Hint="Navigate to timecard page" />

            </StackLayout>
        </Border>

        <Label 
            Text=""
            x:Name="TimePunchAlert"
            Style="{StaticResource SubHeadline}"
            SemanticProperties.HeadingLevel="Level2"
            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

    </VerticalStackLayout>
</ContentPage>