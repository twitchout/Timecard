<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimecardApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="20"
            VerticalOptions="Center">

            <Label 
                Text="Timecard"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1"
                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <Border
                StrokeShape="RoundRectangle 10"
                MaximumWidthRequest="750"
                Margin="0,0,0,100">

                <StackLayout
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                    Padding="15">

                    <Label
                        Text="Email:"
                        Style="{StaticResource SubHeadline}"
                        SemanticProperties.HeadingLevel="Level2" />

                    <Entry
                        x:Name="EmailEntry"
                        Keyboard="Email"
                        MaxLength="100"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Margin="0, 20, 0, 0"
                        Text="Password:"
                        Style="{StaticResource SubHeadline}"
                        SemanticProperties.HeadingLevel="Level2" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Entry
                            Grid.Column="0"
                            x:Name="PasswordEntry"
                            IsPassword="True"
                            MaxLength="100"
                            ReturnType="Done"
                            Completed="OnPasswordCompleted"
                            HorizontalTextAlignment="Center" />
                        <ImageButton
                            Grid.Column="1"
                            x:Name="TogglePasswordBtn"
                            Source="eye.png"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="8"
                            BackgroundColor="Transparent"
                            Clicked="OnTogglePasswordVisibility"
                            VerticalOptions="Center"
                            Aspect="AspectFit"
                            SemanticProperties.Hint="Toggle password visibility" />
                    </Grid>

                    <Label
                        x:Name="ErrorLabel"
                        Margin="0, 10, 0, 0"
                        TextColor="Red"
                        IsVisible="False"
                        HorizontalTextAlignment="Center" />

                    <Button
                        Margin="0, 30, 0, 0"
                        x:Name="LoginBtn"
                        Text="Submit"
                        SemanticProperties.Hint="Submits login information" />

                </StackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
